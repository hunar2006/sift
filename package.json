{
  "name": "sift",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "build": "pnpm --filter @sift-review/core build && pnpm --filter @sift-review/claude-adapter build && pnpm --filter @sift-review/web build && pnpm --filter @sift-review/cli build",
    "check": "pnpm lint && pnpm typecheck && pnpm test && pnpm build",
    "demo": "tsx scripts/make-demo.ts",
    "lint": "eslint .",
    "sift": "node packages/cli/dist/index.js",
    "smoke": "node scripts/smoke.mjs",
    "shots": "tsx scripts/shots.ts",
    "perf": "tsx scripts/perf.ts",
    "pack-check": "tsx scripts/pack-check.ts",
    "preflight": "tsx scripts/preflight/index.ts",
    "eval": "tsx packages/eval/src/cli.ts",
    "fuzz": "tsx packages/eval/src/fuzz.ts",
    "test": "vitest run --coverage",
    "typecheck": "tsc -b"
  },
  "devDependencies": {
    "@sift-review/claude-adapter": "workspace:*",
    "@sift-review/core": "workspace:*",
    "@eslint/js": "^9.20.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.13.4",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^3.0.7",
    "eslint": "^9.20.1",
    "playwright": "^1.61.1",
    "prettier": "^3.5.1",
    "tailwindcss": "^4.0.6",
    "tsup": "^8.3.6",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.24.0",
    "vite": "^6.1.0",
    "vitest": "^3.0.7"
  }
}
