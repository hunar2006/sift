{
  "name": "@sift-review/cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "sift": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup && tsc -p tsconfig.build.json --emitDeclarationOnly && node scripts/copy-assets.mjs",
    "test": "cd ../.. && vitest run packages/cli/src",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "files": [
    "dist/index.js",
    "dist/*.d.ts",
    "dist/*.d.ts.map",
    "dist/web",
    "dist/grammars",
    "package.json"
  ],
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.8",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "chokidar": "^5.0.0",
    "commander": "^13.1.0",
    "fast-xml-parser": "^5.9.3",
    "hono": "^4.7.2",
    "ink": "^7.1.0",
    "open": "^10.1.0",
    "picocolors": "^1.1.1",
    "react": "^19.2.7",
    "tree-sitter-wasms": "^0.1.13",
    "web-tree-sitter": "0.20.8",
    "yaml": "^2.9.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@sift-review/claude-adapter": "0.1.0",
    "@sift-review/core": "0.1.0",
    "@types/react": "^19.2.17",
    "ink-testing-library": "^4.0.0"
  }
}
